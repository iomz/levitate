{
  "name": "levitate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A backend-agnostic MCP stdio-to-HTTP gateway.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iomz/levitate.git"
  },
  "bugs": {
    "url": "https://github.com/iomz/levitate/issues"
  },
  "homepage": "https://github.com/iomz/levitate#readme",
  "bin": {
    "levitate": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.8.3",
    "smol-toml": "^1.4.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.0"
}
